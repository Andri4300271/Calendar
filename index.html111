<style>html, body, button, a, div { touch-action: manipulation !important; -webkit-tap-highlight-color: rgba(74, 158, 255, 0.4) !important; } .nav-btn:active, .ch-btn:active, .dst-btn:active, .file-btn:active, .day-cell:active { background-color: rgba(74, 158, 255, 0.3) !important; transform: scale(0.95) !important; }</style>
-->
<script>document.addEventListener('touchstart',function(e){let t=e.target.closest('button, .day-cell, .nav-btn, .ch-btn, .dst-btn, .file-btn, .month-label');t&&(t.style.backgroundColor='rgba(74, 158, 255, 0.5)',t.style.transform='scale(0.95)')},{passive:!0}),document.addEventListener('touchend',function(e){let t=e.target.closest('button, .day-cell, .nav-btn, .ch-btn, .dst-btn, .file-btn, .month-label');t&&setTimeout(()=>{t.style.backgroundColor='',t.style.transform=''},70)},{passive:!0}),document.addEventListener('touchcancel',function(e){let t=e.target.closest('button, .day-cell, .nav-btn, .ch-btn, .dst-btn, .file-btn, .month-label');t&&(t.style.backgroundColor='',t.style.transform='')},{passive:!0});</script>
<div id="offlineToast" style="display:none;position:fixed;left:50%;top:50%;transform:translate(-50%,calc(-50% + 200px));background:rgba(20,20,25,.95);color:#e8eaf0;padding:20px 32px;border-radius:20px;font-family:Outfit,sans-serif;font-size:30px;font-weight:600;box-shadow:0 4px 16px rgba(0,0,0,.4);z-index:999;opacity:0;transition:opacity .35s ease, transform 1.00s ease;pointer-events:none;text-align:center;">📡<br><span style="white-space:nowrap;">Дані офлайн</span></div>
<script>let offlineToastTimer = null;let offlineToastHideTimer = null;function showOfflineToast() {const el = document.getElementById('offlineToast');if (!el) return;clearTimeout(offlineToastTimer);clearTimeout(offlineToastHideTimer);el.style.display = 'block';el.style.opacity = '0';el.style.transform = 'translate(-50%, calc(-50% + 200px))';requestAnimationFrame(() => {requestAnimationFrame(() => {el.style.opacity = '1';el.style.transform = 'translate(-50%, -50%)';});});offlineToastTimer = setTimeout(() => {el.style.opacity = '0';el.style.transform = 'translate(-50%, calc(-50% - 200px))';offlineToastHideTimer = setTimeout(() => { el.style.display = 'none'; }, 350);}, 3000);}if ('serviceWorker' in navigator) {window.addEventListener('load', () => {navigator.serviceWorker.register('./sw.js').catch(err => {console.error('SW registration failed:', err);});});navigator.serviceWorker.addEventListener('message', (event) => {if (event.data && event.data.type === 'OFFLINE_DATA') {showOfflineToast();}});}</script>
</body>
